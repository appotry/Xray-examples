{
    "inbounds": [
        {
            "tag": "IN-Hysteria2",
            "listen": "0.0.0.0",
            "port": 11451,
            "protocol": "hysteria",
            "settings": {
                "version": 2,
                "clients": [
                    {
                        "auth": "114514" // Hysteria2 密码
                    }
                ]
            },
            "streamSettings": {
                "network": "hysteria",
                "security": "tls",
                "tlsSettings": {
                    "serverName": "114514", // SNI
                    "alpn": [
                        "h3"
                    ], // 这里需要显式写 h3 ，请注意。
                    "certificates": [
                        {
                            "usage": "encipherment",
                            "certificateFile": "/114514/cert.pem",
                            "keyFile": "/114514/key.pem"
                        }
                    ] // 证书设置
                },
                "hysteriaSettings": {
                    "version": 2
                },
                "finalmask": {
                    "udp": [
                        {
                            "type": "salamander",
                            "settings": {
                                "password": "114514" // salamander 混淆密码
                            }
                        }
                    ], // salamander 混淆，不需要可以删除此项
                    "quicParams": {
                        "congestion": "brutal",
                        "brutalUp": "100 mbps",
                        "brutalDown": "100 mbps" // 当与客户端协商启用 brutal ，服务器端使用的速率
                    }
                }
            }
        }
    ]
}
